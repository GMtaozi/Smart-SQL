# ===========================================
# Smart-SQL 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# -----------------------------------------
# AI API 配置（必需）
# -----------------------------------------
# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# -----------------------------------------
# 安全配置（必需）
# -----------------------------------------
# JWT 签名密钥 - 用于用户认证 token
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret-key

# 密码加密密钥 - 用于加密存储数据源密码
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PASSWORD_ENCRYPTION_KEY=your-fernet-key-here

# -----------------------------------------
# 数据库配置（可选，默认使用 docker-compose 配置）
# -----------------------------------------
# DATABASE_URL=postgresql://sqlbot:sqlbot123@postgres:5432/sqlbot

# -----------------------------------------
# 向量同步配置（可选）
# -----------------------------------------
# 禁用自动向量同步（生产环境建议设为 true）
# DISABLE_VECTOR_SYNC=true
