# ============================================
# SQLBot - GitHub 上传用 .gitignore
# ============================================

# ----------------------------------------
# 环境变量和密钥（敏感！）
# ----------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
credentials/

# ----------------------------------------
# Python
# ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
venv/
.venv/
env/

# ----------------------------------------
# Node.js (前端依赖)
# ----------------------------------------
node_modules/
client/node_modules/

# 前端构建产物
client/dist/
client/.nuxt/
client/.output/
client/.vite/

# ----------------------------------------
# IDE 和编辑器
# ----------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------
# Claude Code
# ----------------------------------------
.claude/
.claudeignore/

# ----------------------------------------
# 日志和临时文件
# ----------------------------------------
*.log
logs/
*.tmp
*.temp
.cache/
tmp/
temp/

# ----------------------------------------
# 测试和备份文件
# ----------------------------------------
*.bak
*_backup*
backup/
*.sqlite
*.sqlite3
*.db
test_generate.json

# ----------------------------------------
# 操作系统
# ----------------------------------------
*.icloud
Thumbs.db

# ----------------------------------------
# 压缩包
# ----------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
dist/
releases/

# ----------------------------------------
# TypeScript 缓存
# ----------------------------------------
*.tsbuildinfo
.eslintcache

# ----------------------------------------
# Python 缓存
# ----------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.egg-info/

# ----------------------------------------
# Docker 相关（不需要的）
# ----------------------------------------
.dockerignore
